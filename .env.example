# .env.example
# Copy this file to .env and edit each value.
# Copy example (PowerShell):
#   Copy-Item .env.example .env
#
# The .env file contains secrets used for deployment (subscription ID, API key, etc.),
# so it must not be committed to version control (it is excluded via .gitignore).
#
# -----------------------------------------------------------------------------
# Installing the Azure CLI (az command)
# -----------------------------------------------------------------------------
# The deployment scripts in this project require the Azure CLI.
# If you see an error like the following when running `az login` in PowerShell,
# the Azure CLI is not installed.
#
#   az : The term 'az' is not recognized as the name of a cmdlet, function,
#   script file, or operable program.
#
# Install it with winget (run in PowerShell):
#   winget install --exact --id Microsoft.AzureCLI
#
# After installation, the current PowerShell session will not pick up the
# updated PATH. Close and restart PowerShell before running `az login` etc.
# After restarting, you can verify the installation with:
#   az --version
# -----------------------------------------------------------------------------
#
# -----------------------------------------------------------------------------
# If `az login` fails (e.g. an MFA-required error)
# -----------------------------------------------------------------------------
# Running plain `az login` may sometimes fail with an error like this:
#
#   AADSTS50076: Due to a configuration change made by your administrator,
#   or because you moved to a new location, you must use multi-factor
#   authentication to access ...
#   No subscriptions found for <account>.
#
# In that case, you need to sign in to a different tenant (e.g. your
# organization's tenant) than the default one, by specifying the tenant ID
# explicitly:
#
#   az login --tenant <TENANT_ID>
#
# You can find the tenant ID on the "Microsoft Entra ID" overview page in the
# Azure Portal, or via "Switch directory" in the top-right account menu.
# -----------------------------------------------------------------------------

# Azure subscription ID (required)
# The GUID of the target Azure subscription.
# You can check the current subscription ID with `az account show --query id -o tsv`.
AZURE_SUBSCRIPTION_ID=

# Azure tenant ID (required)
# The GUID of the target Azure Active Directory (Microsoft Entra ID) tenant.
# You can check it with `az account show --query tenantId -o tsv`.
AZURE_TENANT_ID=

# Resource group name (required, has a default value)
# The resource group that holds all resources related to Ollama/Container Apps.
# If you specify an existing resource group name, it will be reused instead of
# being recreated.
AZURE_RESOURCE_GROUP=rg-ollama-gptoss20b

# Deployment region (required, has a default value)
# The Azure region where the Container Apps Environment is created.
# Choose one of the serverless-GPU-capable regions: westus3 (West US 3) or
# swedencentral (Sweden Central).
AZURE_LOCATION=westus3

# Container Apps Environment name (required, has a default value)
# The resource name of the Container Apps Environment that has the GPU
# workload profile.
AZURE_CONTAINER_APPS_ENVIRONMENT=cae-ollama-gptoss20b

# Container App name (required, has a default value)
# The resource name of the Container App that contains the Ollama container
# and the authentication proxy (nginx) sidecar.
AZURE_CONTAINER_APP_NAME=ca-ollama-gptoss20b

# GPU type (required, has a default value)
# The type of GPU assigned to the Container App. Specify either T4 or A100.
AZURE_GPU_TYPE=T4

# Ollama model name (required, has a default value)
# The model name used as the target for `ollama pull` / `ollama run`.
# This deployment is model-agnostic: change this and redeploy to run a different
# model (use a tag that exists at https://ollama.com/library). The only constraint
# is that the model must fit the GPU's VRAM. For larger models, switch to
# AZURE_GPU_TYPE=A100 (T4=16GB / A100=80GB).
#
# VRAM guidance (current setup)   * approximate, Q4 quantization
#   Model size               VRAM (approx)   T4(16GB)     A100(80GB)
#   7B  (qwen2.5:7b, etc.)    ~5GB           yes          yes
#   14B (qwen2.5:14b)         ~9GB           yes          yes
#   gpt-oss:20b (default)     ~13GB          yes (tight)  yes
#   30-32B (qwen3:30b, etc.)  ~18-22GB       no           yes
#   70-72B (qwen2.5:72b)      ~40-45GB       no           yes
#   Kimi K2 (1T MoE)          hundreds of GB no           no  (too large)
#
# Example models you can specify:
#   gpt-oss:20b (default) / qwen3:8b / qwen2.5:7b / qwen2.5:14b / qwen2.5-coder:7b /
#   qwen3:30b (A100) / qwen2.5:72b (A100) / gemma3 / llama3.1 , etc.
OLLAMA_MODEL=gpt-oss:20b

# API key (optional, may be left unset)
# The secret string sent in the X-API-Key request header, required to allow
# access to the public endpoint.
# If left empty, a random value is automatically generated when the
# deployment script runs, and written back to this file. If you specify a
# value yourself, use a random string that is hard to guess.
API_KEY=
